  "details": "<p class=\"mb-2\">USAGE IN ABAP:</p><p class=\"mb-2\">SELECT * FROM ZPRAC_CDS_SIMPLE</p><p class=\"mb-2\">INTO TABLE @DATA(lt_travel).</p><p class=\"mb-2\">SELECT TravelId, AgencyId, TotalPrice</p><p class=\"mb-2\">FROM ZPRAC_CDS_SIMPLE</p><p class=\"mb-2\">INTO TABLE @DATA(lt_travel_short)</p><p class=\"mb-2\">WHERE CustomerId = '000115'.</p><p class=\"mb-2\">DIAGRAM: assets/diagrams/cds-syntax.svg</p>",
