= -->\n  <rect x=\"40\" y=\"375\" width=\"920\" height=\"85\" rx=\"8\" fill=\"#FEF2F2\" stroke=\"#EF4444\" stroke-width=\"2\"/>\n  <text x=\"65\" y=\"398\" font-size=\"14\" font-weight=\"bold\" fill=\"#DC2626\">4. Data Model Layer</text>\n\n  <rect x=\"65\" y=\"410\" width=\"220\" height=\"40\" rx=\"4\" fill=\"#FEE2E2\" stroke=\"#EF4444\" stroke-width=\"1\"/>\n  <text x=\"175\" y=\"428\" text-anchor=\"middle\" font-size=\"10\" fill=\"#991B1B\">CDS View Entity (Root)</text>\n  <text x=\"175\" y=\"442\" text-anchor=\"middle\" font-size=\"8\" fill=\"#64748B\">define root view entity</text>\n\n  <rect x=\"305\" y=\"410\" width=\"220\" height=\"40\" rx=\"4\" fill=\"#FEE2E2\" stroke=\"#EF4444\" stroke-width=\"1\"/>\n  <text x=\"415\" y=\"428\" text-anchor=\"middle\" font-size=\"10\" fill=\"#991B1B\">CDS Projection View</text>\n  <text x=\"415\" y=\"442\" text-anchor=\"middle\" font-size=\"8\" fill=\"#64748B\">define root view entity (projection)</text>\n\n  <rect x=\"545\" y=\"410\" width=\"220\" height=\"40\" rx=\"4\" fill=\"#FEE2E2\" stroke=\"#EF4444\" stroke-width=\"1\"/>\n  <text x=\"655\" y=\"428\" text-anchor=\"middle\" font-size=\"10\" fill=\"#991B1B\">Metadata Extension</text>\n  <text x=\"655\" y=\"442\" text-anchor=\"middle\" font-size=\"8\" fill=\"#64748B\">@MetadataExtension: true</text>\n\n  <rect x=\"785\" y=\"410\" width=\"140\" height=\"40\" rx=\"4\" fill=\"#FEE2E2\" stroke=\"#EF4444\" stroke-width=\"1\"/>\n  <text x=\"855\" y=\"428\" text-anchor=\"middle\" font-size=\"10\" fill=\"#991B1B\">RAP BO</text>\n  <text x=\"855\" y=\"442\" text-anchor=\"middle\" font-size=\"8\" fill=\"#64748B\">Business Object</text>\n\n  <line x1=\"65\" y1=\"460\" x2=\"65\" y2=\"490\" stroke=\"#E95420\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n\n  <!-- ============ LAYER 5: Database ============ -->\n  <rect x=\"40\" y=\"495\" width=\"920\" height=\"55\" rx=\"8\" fill=\"#EDE9FE\" stroke=\"#A855F7\" stroke-width=\"2\"/>\n  <text x=\"65\" y=\"518\" font-size=\"14\" font-weight=\"bold\" fill=\"#9333EA\">5. Database Layer</text>\n  <text x=\"65\" y=\"538\" font-size=\"10\" fill=\"#1e293b\">SAP HANA · DDIC Tables · Table Functions · AMDP · ABAP SQL via Open SQL</text>\n\n  <line x1=\"65\" y1=\"550\" x2=\"65\" y2=\"580\" stroke=\"#E95420\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n\n  <!-- ============ FULL REQUEST FLOW ============ -->\n  <rect x=\"40\" y=\"585\" width=\"920\" height=\"200\" rx=\"8\" fill=\"#F8FAFC\" stroke=\"#CBD5E1\" stroke-width=\"1\"/>\n  <text x=\"500\" y=\"610\" text-anchor=\"middle\" font-size=\"14\" font-weight=\"bold\" fill=\"#1e293b\">RAP Request Flow — End to End</text>\n  <line x1=\"60\" y1=\"618\" x2=\"940\" y2=\"618\" stroke=\"#E2E8F0\" stroke-width=\"1\"/>\n\n  <text x=\"80\" y=\"642\" font-size=\"10\" font-weight=\"bold\" fill=\"#64748B\">Step</text>\n  <text x=\"200\" y=\"642\" font-size=\"10\" font-weight=\"bold\" fill=\"#64748B\">Component</text>\n  <text x=\"450\" y=\"642\" font-size=\"10\" font-weight=\"bold\" fill=\"#64748B\">What Happens</text>\n  <line x1=\"80\" y1=\"648\" x2=\"900\" y2=\"648\" stroke=\"#E2E8F0\" stroke-width=\"1\"/>\n\n  <text x=\"80\" y=\"668\" font-size=\"10\" font-weight=\"bold\" fill=\"#22C55E\">1</text>\n  <text x=\"200\" y=\"668\" font-size=\"10\" fill=\"#1e293b\">Fiori / UI5</text>\n  <text x=\"450\" y=\"668\" font-size=\"10\" fill=\"#1e293b\">User triggers a request (list report, object page, action)</text>\n\n  <text x=\"80\" y=\"688\" font-size=\"10\" font-weight=\"bold\" fill=\"#22C55E\">2</text>\n  <text x=\"200\" y=\"688\" font-size=\"10\" fill=\"#1e293b\">Service Binding</text>\n  <text x=\"450\" y=\"688\" font-size=\"10\" fill=\"#1e293b\">OData V4 URL → maps to Service Definition entities</text>\n\n  <text x=\"80\" y=\"708\" font-size=\"10\" font-weight=\"bold\" fill=\"#EAB308\">3</text>\n  <text x=\"200\" y=\"708\" font-size=\"10\" fill=\"#1e293b\">Behavior Definition</text>\n  <text x=\"450\" y=\"708\" font-size=\"10\" fill=\"#1e293b\">EML → routes to create/update/delete or query implementation</text>\n\n  <text x=\"80\" y=\"728\" font-size=\"10\" font-weight=\"bold\" fill=\"#EAB308\">4</text>\n  <text x=\"200\" y=\"728\" font-size=\"10\" fill=\"#1e293b\">Behavior Implementation</text>\n  <text x=\"450\" y=\"728\" font-size=\"10\" fill=\"#1e293b\">ABAP class: FOR MODIFY / FOR READ methods execute logic</text>\n\n  <text x=\"80\" y=\"748\" font-size=\"10\" font-weight=\"bold\" fill=\"#EF4444\">5</text>\n  <text x=\"200\" y=\"748\" font-size=\"10\" fill=\"#1e293b\">CDS View Entity</text>\n  <text x=\"450\" y=\"748\" font-size=\"10\" fill=\"#1e293b\">SQL statement generated from CDS → Open SQL → HANA</text>\n\n  <text x=\"80\" y=\"768\" font-size=\"10\" font-weight=\"bold\" fill=\"#A855F7\">6</text>\n  <text x=\"200\" y=\"768\" font-size=\"10\" fill=\"#1e293b\">SAP HANA</text>\n  <text x=\"450\" y=\"768\" font-size=\"10\" fill=\"#1e293b\">Data returned to EML → serialized to OData V4 JSON → Fiori</text>\n<text x=\"10\" y=\"20\" font-size=\"8\" fill=\"rgba(233,84,32,0.15)\" font-family=\"sans-serif\">cds-bytes (c) 2026</text></svg></div>\n<h2 id=\"section-ZPRAC_RAP_BEHAVIOR-cds-source-code\">CDS Source Code</h2>\n<pre><code class=\"language-abap\">managed implementation in class ZCL_RAP_TRAVEL unique;\nstrict ( 2 );\nwith draft;\n\ndefine behavior for ZPRAC_CDS_VIEW_ENTITY alias Travel\npersistent table /dmo/travel\nlock master\nauthorization master ( instance )\n{\n  field ( readonly : update ) TravelId, Createdby, Createdat;\n  field ( mandatory ) AgencyId, CustomerId, BeginDate, EndDate;\n  create;\n  update;\n  delete;\n\n  action ( features : instance ) acceptBooking result [1] $self;\n\n  mapping for /dmo/travel\n  {\n    TravelId = travel_id;\n    AgencyId = agency_id;\n    CustomerId = customer_id;\n    BeginDate = begin_date;\n    EndDate = end_date;\n  }\n}\n\ndefine behavior for ZPRAC_CDS_ASSOCIATION alias Booking\npersistent table /dmo/booking\nlock dependent by _Travel\n{\n  update;\n  delete;\n  association _Travel;\n}</code></pre>","tags":["rap"],"details":"<p class=\"mb-2\">what operations (CRUD, actions, validations) are allowed on</p><p class=\"mb-2\">a CDS view entity and how they behave</p><p class=\"mb-2\">save/update/delete logic automatically; unmanaged requires</p><p class=\"mb-2\">manual implementation in a handler class for full control</p><p class=\"mb-2\">users can save incomplete changes before publishing (activate)</p><p class=\"mb-2\">node; if omitted, the operation is not allowed</p><p class=\"mb-2\">to a pool class with handler methods for custom logic</p><p class=\"mb-2\">mandatory fields); determinations auto-execute on triggers</p><p class=\"mb-2\">(e.g., set status on create)</p><p class=\"mb-2\">a single entity (e.g., acceptBooking), static actions on</p><p class=\"mb-2\">the whole set (e.g., bulkArchive)</p><p class=\"mb-2\">no obsolete statements, mandatory field controls)</p><p class=\"mb-2\">KEY RULES — RAP BDEF Requirements:</p><p class=\"mb-2\">┌───────────────────────────────────┬─────────────────────────────────┐</p><p class=\"mb-2\">│ Rule                              │ Description                     │</p><p class=\"mb-2\">├───────────────────────────────────┼─────────────────────────────────┤</p><p class=\"mb-2\">│ Root entity must have a           │ persistent table /dmo/...     │</p><p class=\"mb-2\">│ persistent table assigned         │                                 │</p><p class=\"mb-2\">│ Child entities must use           │ lock dependent by _Parent      │</p><p class=\"mb-2\">│ lock dependent                    │                                 │</p><p class=\"mb-2\">│ authorization master (instance)   │ Enables instance-based auth     │</p><p class=\"mb-2\">│ on root node                      │                                 │</p><p class=\"mb-2\">│ field ( readonly : update )       │ Protect fields from change      │</p><p class=\"mb-2\">│ for admin fields (CreatedBy, …)   │ after creation                  │</p><p class=\"mb-2\">│ field ( mandatory ) for required  │ Enforces not-null on create     │</p><p class=\"mb-2\">│ business fields                   │                                 │</p><p class=\"mb-2\">│ mapping for ... { ... }           │ Maps CDS field names to DB cols │</p><p class=\"mb-2\">│                                   │                                 │</p><p class=\"mb-2\">│ Strict(2) is MANDATORY for        │ Required for cloud / SAP BTP    │</p><p class=\"mb-2\">│ cloud-ready RAP BOs               │                                 │</p><p class=\"mb-2\">└───────────────────────────────────┴─────────────────────────────────┘</p><p class=\"mb-2\">DIAGRAM: assets/diagrams/rap-arch.svg</p>","cdsViewName":"ZPRAC_RAP_BEHAVIOR","sqlViewName":"ZPRAC_SQL_RAPBH","topic":"ABAP RESTful Application Programming Model — Behavior Definition"}